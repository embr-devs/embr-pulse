# ---------- Auth (NextAuth + Entra) ----------
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Microsoft Entra app registration for embr-pulse
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT=

# Comma-separated email allowlist (e.g. alice@microsoft.com,bob@microsoft.com)
AUTH_ALLOWED_EMAILS=

# ---------- Database ----------
# Set by Embr in production. For local dev, run a Postgres container and point this here.
DATABASE_URL=postgresql://localhost:5432/embr_pulse

# ---------- GitHub App (embr-pulse-bot) ----------
# Used to create issues, assign Copilot, listen to webhooks.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# Multi-line PEM. In Embr env vars, paste the full PEM with literal newlines.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# The repo where issues will be created (owner/name)
GITHUB_REPO=seligj95/embr-pulse

# ---------- Foundry (set in Phase 3) ----------
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_API_KEY=
FOUNDRY_TRIAGE_AGENT_ID=
FOUNDRY_MONITOR_AGENT_ID=
FOUNDRY_MODEL_DEPLOYMENT=

# ---------- App Insights (set in Phase 1) ----------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---------- Internal agent endpoint auth ----------
# Bearer token used by GH Actions cron → /api/agents/monitor/run
AGENT_INTERNAL_TOKEN=

# ---------- Feature flags ----------
# When "true", POST /api/feedback returns 500 for ~1% of requests (synthetic incident demo).
EMBR_PULSE_SIMULATE_FAILURE=false
