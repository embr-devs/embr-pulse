    "test:watch": "vitest",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.9.1",
    "@octokit/auth-app": "^7.1.4",
    "@octokit/rest": "^21.1.1",
    "@opentelemetry/api-logs": "^0.216.0",
    "next": "^15.5.15",
    "next-auth": "^5.0.0-beta.25",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  },
  "engines": {
