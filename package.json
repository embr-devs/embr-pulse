{
  "name": "embr-pulse",
  "version": "0.1.0",
  "private": true,
  "description": "Team feedback aggregator hosted on Embr — managed end-to-end by agents. Demo for github.com/coreai-microsoft/embr/issues/374.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
